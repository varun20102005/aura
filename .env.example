# AURA Environment Variables Configuration
# Copy this file to .env and adjust values as needed.

# Database connection string (defaults to docker-compose postgres container)
DATABASE_URL=postgresql://aura:aurapass@postgres:5432/auradb

# Security secret for JWT Tokens (Replace with a strong random string in production)
JWT_SECRET_KEY=replace_with_a_secure_random_string

# Gemini API Key for AI Summaries (Optional)
GEMINI_API_KEY=your_gemini_key_here

# SMTP Configuration for Email Notifications (Optional)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@aura.local
